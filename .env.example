# EmailEngine / SMTP configuration
# Copy this file to .env and set real values.

# EmailEngine API endpoint used by email-service
EMAILENGINE_BASE_URL=http://emailengine:3000

# EmailEngine runtime options
# Keep false for local development, or set true and configure EMAILENGINE_API_TOKEN.
EMAILENGINE_REQUIRE_API_AUTH=false
EENGINE_REDIS=redis://redis:6379/8
EENGINE_SECRET=replace-with-a-long-random-secret
EMAILENGINE_API_TOKEN=

# SMTP provider settings (required for auto-bootstrap)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Alfit Gym
SMTP_SECURE=false
